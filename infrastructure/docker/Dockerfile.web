# SCR Platform — Next.js Web App (standalone output)
# Build context: repo root
# Requires next.config.mjs output: "standalone"
# docker build -f infrastructure/docker/Dockerfile.web -t scr-web .

FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# ── Dependencies ──────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

# Copy manifests only (cache-friendly — only reinstalls on lockfile change)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/
COPY packages/ui/package.json ./packages/ui/
COPY packages/types/package.json ./packages/types/
COPY packages/config/package.json ./packages/config/

RUN pnpm install --frozen-lockfile

# ── Builder ───────────────────────────────────────────────────────────────────
FROM base AS builder
WORKDIR /app

# Build-time env vars (NEXT_PUBLIC_* are baked into the JS bundle)
ARG NEXT_PUBLIC_API_URL=http://localhost:8000
ARG NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
ARG NEXT_PUBLIC_SENTRY_DSN=""
ARG NEXT_PUBLIC_APP_ENV="staging"
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL \
    NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=$NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY \
    NEXT_PUBLIC_SENTRY_DSN=$NEXT_PUBLIC_SENTRY_DSN \
    NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV

# Restore the pnpm virtual store so the build can resolve workspace links
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
# Packages have local devDependencies (typescript) — copy their node_modules too
COPY --from=deps /app/packages/types/node_modules ./packages/types/node_modules
COPY --from=deps /app/packages/ui/node_modules ./packages/ui/node_modules
COPY --from=deps /app/packages/config/node_modules ./packages/config/node_modules

# Source code (after node_modules copy to preserve layer caching)
COPY packages/ ./packages/
COPY apps/web/ ./apps/web/
COPY package.json pnpm-workspace.yaml ./

# Ensure public dir exists (app has no static assets but Next.js expects it)
RUN mkdir -p apps/web/public

# Build shared packages first, then the app
RUN pnpm --filter @scr/types build && \
    pnpm --filter @scr/ui build && \
    pnpm --filter @scr/web build

# ── Runner (minimal final image) ──────────────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

# Non-root user
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# outputFileTracingRoot=monorepo-root causes standalone to mirror the full
# directory tree from the repo root.  After the copy:
#   /app/apps/web/server.js          ← entry point
#   /app/apps/web/.next/server/      ← server-side chunks
#   /app/node_modules/               ← all server deps (incl. 'next')
# Static assets must be placed where server.js expects them:
#   /app/apps/web/.next/static/
#   /app/apps/web/public/
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

USER nextjs

# Use 127.0.0.1 (not localhost) — BusyBox wget resolves localhost → ::1 (IPv6)
# but Next.js only binds IPv4. /api/health returns 200 without auth.
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD wget -qO- http://127.0.0.1:3000/api/health || exit 1

EXPOSE 3000
ENV PORT=3000 HOSTNAME="0.0.0.0"

# server.js lives at apps/web/server.js within the standalone tree
CMD ["node", "apps/web/server.js"]
