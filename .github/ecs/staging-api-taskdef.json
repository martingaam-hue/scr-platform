{
  "containerDefinitions": [
    {
      "name": "api",
      "image": "547279162499.dkr.ecr.eu-north-1.amazonaws.com/scr-api:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "AWS_SES_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "APP_ENV",
          "value": "staging"
        },
        {
          "name": "AWS_S3_BUCKET",
          "value": "scr-staging-documents"
        },
        {
          "name": "APP_DEBUG",
          "value": "false"
        },
        {
          "name": "FRONTEND_URL",
          "value": "https://scr-platform-web-2.vercel.app"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/DATABASE_URL"
        },
        {
          "name": "DATABASE_URL_READ_REPLICA",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/DATABASE_URL_READ_REPLICA"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/REDIS_URL"
        },
        {
          "name": "CELERY_BROKER_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/CELERY_BROKER_URL"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/SECRET_KEY"
        },
        {
          "name": "CLERK_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/CLERK_SECRET_KEY"
        },
        {
          "name": "CLERK_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/CLERK_WEBHOOK_SECRET"
        },
        {
          "name": "CLERK_ISSUER_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/CLERK_ISSUER_URL"
        },
        {
          "name": "AI_GATEWAY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/AI_GATEWAY_API_KEY"
        },
        {
          "name": "AI_GATEWAY_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/AI_GATEWAY_URL"
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/ANTHROPIC_API_KEY"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/OPENAI_API_KEY"
        },
        {
          "name": "GOOGLE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/GOOGLE_API_KEY"
        },
        {
          "name": "XAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/XAI_API_KEY"
        },
        {
          "name": "DEEPSEEK_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/DEEPSEEK_API_KEY"
        },
        {
          "name": "PINECONE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/PINECONE_API_KEY"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/RESEND_API_KEY"
        },
        {
          "name": "SENTRY_DSN",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/SENTRY_DSN"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/AWS_ACCESS_KEY_ID"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/AWS_SECRET_ACCESS_KEY"
        },
        {
          "name": "HUBSPOT_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/HUBSPOT_CLIENT_ID"
        },
        {
          "name": "HUBSPOT_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/HUBSPOT_CLIENT_SECRET"
        },
        {
          "name": "SALESFORCE_CONSUMER_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/SALESFORCE_CONSUMER_KEY"
        },
        {
          "name": "SALESFORCE_CONSUMER_SECRET",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/SALESFORCE_CONSUMER_SECRET"
        },
        {
          "name": "FRED_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/FRED_API_KEY"
        },
        {
          "name": "ALPHA_VANTAGE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/ALPHA_VANTAGE_API_KEY"
        },
        {
          "name": "EMBER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/EMBER_API_KEY"
        },
        {
          "name": "EIA_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/EIA_API_KEY"
        },
        {
          "name": "OPENWEATHER_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/OPENWEATHER_API_KEY"
        },
        {
          "name": "COMPANIES_HOUSE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:547279162499:secret:scr/staging/COMPANIES_HOUSE_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/scr-staging/api",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "api"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 15
      },
      "systemControls": []
    }
  ],
  "family": "scr-api-staging",
  "taskRoleArn": "arn:aws:iam::547279162499:role/scr-staging-ecs-task",
  "executionRoleArn": "arn:aws:iam::547279162499:role/scr-staging-ecs-exec",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024"
}
